\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Correlations between the realized step length $(l_t)$ and the absolute value of the turn angle $\left (\envert {a_t}\right )$ calculated from 100000 draws from a position-based correlated random walk in the Cartesian plane (Eq.\ \ref {eq:crw}) with $\sigma _x=\sigma _y=1$, lag 1 autocorrelation parameter $\beta \in \left (-1,1\right )$, and easting-northing correlation parameter $\rho \in \{-0.5,0,0.5\}$. Note that when $\beta =0$, the model reduces to a simple random walk and the realized steps and turns are no longer correlated.\relax }}{9}{figure.caption.1}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:corrPlot}{{1}{9}{Correlations between the realized step length $(l_t)$ and the absolute value of the turn angle $\left (\abs {a_t}\right )$ calculated from 100000 draws from a position-based correlated random walk in the Cartesian plane (Eq.\ \ref {eq:crw}) with $\sigma _x=\sigma _y=1$, lag 1 autocorrelation parameter $\beta \in \left (-1,1\right )$, and easting-northing correlation parameter $\rho \in \{-0.5,0,0.5\}$. Note that when $\beta =0$, the model reduces to a simple random walk and the realized steps and turns are no longer correlated.\relax }{figure.caption.1}{}}
